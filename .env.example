# ============================================================
# MindNote — Environment variables
# ============================================================
# Copy this file to .env.local for local development.
# For Vercel, set the same variables via:
#   vercel env add VITE_DROPBOX_APP_KEY production
#   vercel env add VITE_DROPBOX_APP_KEY preview
#   vercel env add VITE_DROPBOX_APP_KEY development
# ============================================================

# Dropbox sync (optional). Create app at https://www.dropbox.com/developers/apps
# Redirect URI must be: https://<your-domain>/dropbox-callback
VITE_DROPBOX_APP_KEY=

# Google Drive sync has been removed from this build.
# Leave the next line commented out — it is here only as a reference
# for anyone porting an older version.
# VITE_GOOGLE_CLIENT_ID=
